# Cloudinary (for upload script only – use local .env, never commit real values)
# Get these from https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Optional: if you use CLOUDINARY_URL format (single variable)
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
