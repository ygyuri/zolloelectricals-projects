# Admin session (required for /admin login)
# Generate a random string, e.g. openssl rand -base64 32
ADMIN_SESSION_SECRET=

# WordPress (for admin login – use Application Password from WP Profile)
WORDPRESS_SITE_URL=https://zolloelectricals.com

# Vercel KV / Upstash Redis (from Vercel dashboard or Upstash)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Cloudinary (upload script + client upload preset)
CLOUDINARY_CLOUD_NAME=duelwg6z9
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Client-side (for admin form uploads – create unsigned preset in Cloudinary)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=duelwg6z9
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=
